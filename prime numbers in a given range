# Function to check if a number is prime
def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num ** 0.5) + 1):
        if num % i == 0:
            return False
    return True

# Input
start = int(input())
end = int(input())

# Find and print primes
found = False
for num in range(start, end + 1):
    if is_prime(num):
        print(num)
        found = True

# If no primes found
if not found:
    print("No primes")
